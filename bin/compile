#!/usr/bin/env bash
# Cold bootstrap → native, self-built compiler via the manifest.
#
#   bin/compile [output_path]      (default output: bin/manticore)
#
# Two stages, because the manifest build (`manticore build`) cannot run under
# Zend — its file IO fills mutable libc buffers, which Zend's immutable strings
# can't provide:
#
#   1. Zend front-end compiles src/ → a THROWAWAY *seed* binary (the only
#      Zend-built artifact). Runtime-free: every external symbol is resolved by
#      libc at link time or stubbed via the generated stubs.c (void* → 0).
#   2. The seed runs `build manticore.json` → the SHIPPED native compiler
#      (self-contained) AND the prebuilt stdlib library
#      (lib/manticore_stdlib.{o,sig}). One manifest now defines every artifact,
#      so this seed path and `bin/build`'s self-host path share a definition.

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

# The Zend seed front-end (compile_files_mir.php) can't resolve the prelude via
# argv0 (the libc argv binding is a stub under Zend), so point it at the
# canonical dir — prelude fns the COMPILER ITSELF uses (e.g. explode) must be
# injected into the seed, or the seed links with `@manticore_<fn>` undefined.
export MANTICORE_PRELUDE="$ROOT/prelude"

OUT="${1:-bin/manticore}"
mkdir -p "$(dirname "$OUT")"

SEED_DIR="$(mktemp -d)"
SEED="$SEED_DIR/manticore_seed"
LL="$SEED_DIR/seed.ll"
OBJ="$SEED_DIR/seed.o"
STUBS_PREFIX="$SEED_DIR/seed"

echo "[1/5] Zend bootstrap: src/ -> seed IR"
# `find | sort` puts zzz_entry.php (the top-level driver) last so every class /
# function is registered by the time its top-level lowers into main().
find src -name "*.php" | sort | xargs php -d memory_limit=2048M tools/compile_files_mir.php > "$LL"

echo "[2/5] assemble seed -> $OBJ"
clang -c "$LL" -o "$OBJ" -Wno-override-module

echo "[3/5+4/5] stub undefined symbols, link seed -> $SEED"
# Probe the linker without the runtime lib — every symbol it still can't find
# gets a void* fallback, then link. Shared with tools/selfhost.sh: the symbol
# extraction has to understand Apple ld, GNU ld and lld, and one copy of that
# is enough (it was three, all Apple-only — issue #1).
STUBS_PREFIX="$STUBS_PREFIX" bash tools/link_stubs.sh "$SEED" "$OBJ"

# Install the prelude beside the shipped stdlib object: `lib/prelude/` is one of
# find_prelude_src's argv0-relative candidates, so a distribution is binary + lib/
# and needs no MANTICORE_PRELUDE. Done BEFORE the seed runs — the seed compiles
# the compiler, and the compiler it produces must find its prelude the same way.
mkdir -p lib/prelude
cp prelude/*.php lib/prelude/

echo "[5/5] seed builds the manifest -> $OUT + lib/manticore_stdlib.{o,sig}"
# The manifest's application output is bin/manticore; redirect it to $OUT when a
# custom path was requested (bin/build --seed passes a temp). The seed lives in
# a temp dir, never $OUT, so it never overwrites the binary it's running as.
MANIFEST="manticore.json"
if [[ "$OUT" != "bin/manticore" ]]; then
    MANIFEST="$SEED_DIR/manticore.json"
    sed "s#\"bin/manticore\"#\"$OUT\"#" manticore.json > "$MANIFEST"
fi
"$SEED" build "$MANIFEST"

echo "── smoke test the native build ──"
echo '<?php echo "selfhost-ok\n";' > "$SEED_DIR/smoke.php"
"$OUT" compile "$SEED_DIR/smoke.php" -o "$SEED_DIR/smoke" >/dev/null
OUTPUT="$("$SEED_DIR/smoke")"
if [[ "$OUTPUT" != "selfhost-ok" ]]; then
    echo "fatal: smoke test failed (got '$OUTPUT')" >&2
    exit 1
fi
echo "ok: $OUT (native, self-built via manifest) + lib/manticore_stdlib.o"
