; passes: lower-from-ast, const-fold, dead-store, infer-types, monomorphize, narrow-returns, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops

fn build() -> int {
  mem_arena_enter
  %0 = int_const 1 : int
  %1 = int_const 2 : int
  %2 = int_const 3 : int
  %3 = array_lit [_ => %0, _ => %1, _ => %2] : vec[int]
  %4 = store_local a <- %3 : vec[int]
  %5 = load_local a : vec[int]
  %6 = int_const 1 : int
  %7 = int_const 20 : int
  %8 = store_element %5[%6] <- %7 : int
  %9 = load_local a : vec[int]
  %10 = int_const 1 : int
  %11 = array_access %9[%10] : int
  return %11
  mem_arena_leave
}

fn __main() -> int {
  %0 = call build() : int
  echo %0
}
