; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops

fn area(float %r) -> float {
  %0 = float_const 3.14 : float
  %1 = load_local r : float
  %2 = mul %0, %1 : float
  %3 = load_local r : float
  %4 = mul %2, %3 : float
  return %4
}

fn __main() -> int {
  %0 = float_const 2 : float
  %1 = call area(%0) : float
  echo %1
}
