; passes: lower-from-ast, const-fold, dead-store, infer-types, monomorphize, narrow-returns, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops

fn sign(int %n) -> int {
  %0 = load_local n : int
  %1 = int_const 0 : int
  %2 = cmp > %0, %1 : bool
  if %2 then {
    %3 = int_const 1 : int
    return %3
  } else {
    %4 = int_const -1 : int
    return %4
  }
}

fn __main() -> int {
  %0 = int_const 5 : int
  %1 = call sign(%0) : int
  echo %1
}
