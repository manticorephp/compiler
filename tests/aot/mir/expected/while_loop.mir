; passes: lower-from-ast, const-fold, dead-store, infer-types, monomorphize, narrow-returns, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops

fn countdown(int %n) -> int {
  %0 = int_const 0 : int
  %1 = store_local acc <- %0 : int
  while {
    %2 = load_local n : int
    %3 = int_const 0 : int
    %4 = cmp > %2, %3 : bool
    check %4
    %5 = load_local acc : int
    %6 = load_local n : int
    %7 = add %5, %6 : int
    %8 = store_local acc <- %7 : int
    %9 = load_local n : int
    %10 = int_const 1 : int
    %11 = sub %9, %10 : int
    %12 = store_local n <- %11 : int
  }
  %13 = load_local acc : int
  return %13
}

fn __main() -> int {
  %0 = int_const 5 : int
  %1 = call countdown(%0) : int
  echo %1
}
