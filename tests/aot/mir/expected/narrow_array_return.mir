; passes: lower-from-ast, const-fold, dead-store, infer-types, monomorphize, narrow-returns, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops

fn build() -> vec[int] {
  %0 = array_lit [] : vec[unknown]
  %1 = store_local out <- %0 : vec[unknown]
  %2 = load_local out : vec[unknown]
  %3 = null_const : null
  %4 = int_const 1 : int
  %5 = store_element %2[%3] <- %4 : int
  %6 = load_local out : vec[int]
  %7 = null_const : null
  %8 = int_const 2 : int
  %9 = store_element %6[%7] <- %8 : int
  %10 = load_local out : vec[int]
  return %10
  mem_rc_release vec out
}

fn __main() -> int {
  %0 = call build() : vec[int]
  %1 = store_local x <- %0 : vec[int]
  %2 = load_local x : vec[int]
  %3 = int_const 0 : int
  %4 = array_access %2[%3] : int
  echo %4
  mem_rc_release vec x
}
