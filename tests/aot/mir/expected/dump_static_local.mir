; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn seq() -> int {
  %0 = int_const 0 : int
  %1 = static_local_decl n cell=@seq__sl_n guard=@seq__sl_n__init <- %0 : int
  %2 = incdec n++ : int
  %3 = load_local n : int
  return %3
}

fn __main() -> int {
  %0 = call seq() : int
  %1 = call seq() : int
  %2 = call seq() : int
  echo %0, %1, %2
}
