; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn area(float %r) -> float {
  ; effects: escape
  %0 = float_const 3.14 : float
  %1 = load_local r : float
  %2 = mul %0, %1 : float
  %3 = load_local r : float
  %4 = mul %2, %3 : float
  return %4  ; eff: escape
}

fn __main() -> int {
  ; effects: throw
  %0 = float_const 2 : float
  %1 = call area(%0) : float  ; eff: throw
  echo %1
}
