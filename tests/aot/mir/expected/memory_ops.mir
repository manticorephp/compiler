; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn frees(int %n, string %borrowed) -> void {
  mem_arena_enter
  %0 = string_const "tmp" : string
  %1 = load_local n : int
  %2 = concat %0, %1 : string
  %3 = store_local s <- %2 : string
  %4 = load_local n : int
  %5 = load_local n : int
  %6 = array_lit [_ => %4, _ => %5] : vec[int]
  %7 = store_local a <- %6 : vec[int]
  %8 = load_local borrowed : string
  %9 = store_local b <- %8 : string
  %10 = load_local s : string
  echo %10
  %11 = load_local a : vec[int]
  %12 = int_const 0 : int
  %13 = array_access %11[%12] : int
  echo %13
  %14 = load_local b : string
  echo %14
  mem_arena_leave
}

fn __main() -> int {
  %0 = int_const 1 : int
  %1 = string_const "x" : string
  %2 = call frees(%0, %1) : void
}
