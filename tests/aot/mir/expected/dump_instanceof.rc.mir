; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn check(obj<Animal> %a) -> bool {
  ; effects: escape
  %0 = load_local a : obj<Animal>
  %1 = instanceof %0, Dog : bool
  return %1  ; eff: escape
}

fn __main() -> int {
  ; effects: alloc,throw
  %0 = new Dog() : obj<Dog>  ; eff: alloc,throw alloc=RcHeap
  %1 = call check(%0) : bool  ; eff: throw
  ternary %1 then {
    %2 = string_const "y" : string
    -> %2
  } else {
    %3 = string_const "n" : string
    -> %3
  } => %4 : string
  echo %4
}
