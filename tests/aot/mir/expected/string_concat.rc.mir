; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn greet(string %name) -> string {
  ; effects: alloc,escape
  %0 = string_const "hello, " : string
  %1 = load_local name : string
  %2 = concat %0, %1 : string  ; eff: alloc alloc=NoRefcount
  %3 = store_local msg <- %2 : string
  %4 = load_local msg : string
  %5 = string_const "!" : string
  %6 = concat %4, %5 : string  ; eff: alloc alloc=RcHeap
  return %6  ; eff: escape
  mem_release string msg
}

fn __main() -> int {
  ; effects: throw
  %0 = string_const "world" : string
  %1 = call greet(%0) : string  ; eff: throw
  echo %1
}
