; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn sw(int %x) -> string {
  %0 = load_local x : int
  switch %0 {
    arm {
      %1 = int_const 1 : int
      on %1
      %2 = string_const "one" : string
      return %2
    }
    arm {
      %3 = int_const 2 : int
      on %3
      %4 = string_const "two" : string
      return %4
    }
    arm default {
      %5 = string_const "many" : string
      return %5
    }
  }
}

fn __main() -> int {
  %0 = int_const 1 : int
  %1 = call sw(%0) : string
  %2 = int_const 5 : int
  %3 = call sw(%2) : string
  echo %1, %3
}
