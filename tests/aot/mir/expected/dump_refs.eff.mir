; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn bump(vec[int] %a) -> void {
  ; effects: (none)
  %0 = load_local a : vec[int]
  %1 = int_const 0 : int
  %2 = array_access %0[%1] : int
  ref_addr r = &%2
  %3 = load_local r : int
  %4 = int_const 100 : int
  %5 = add %3, %4 : int
  %6 = store_local r <- %5 : int
}

fn firstOf(vec[int] %a) -> int {
  ; effects: escape
  %0 = load_local a : vec[int]
  %1 = int_const 1 : int
  %2 = array_access %0[%1] : int
  return %2  ; eff: escape
}

fn refs() -> int {
  ; effects: alloc,escape,throw
  %0 = int_const 5 : int
  %1 = store_local x <- %0 : int
  ref_alias y = &x
  %2 = int_const 10 : int
  %3 = store_local y <- %2 : int
  %4 = int_const 1 : int
  %5 = int_const 2 : int
  %6 = array_lit [_ => %4, _ => %5] : vec[int]  ; eff: alloc alloc=RcHeap
  %7 = store_local arr <- %6 : vec[int]
  %8 = load_local arr : vec[int]
  %9 = call bump(%8) : void  ; eff: throw
  %10 = load_local arr : vec[int]
  %11 = call firstOf(%10) : int  ; eff: throw
  ref_bind r = &%11
  %12 = int_const 50 : int
  %13 = store_local r <- %12 : int
  %14 = load_local x : int
  %15 = load_local arr : vec[int]
  %16 = int_const 0 : int
  %17 = array_access %15[%16] : int
  %18 = add %14, %17 : int
  %19 = load_local arr : vec[int]
  %20 = int_const 1 : int
  %21 = array_access %19[%20] : int
  %22 = add %18, %21 : int
  return %22  ; eff: escape
  mem_rc_release vec arr
}

fn __main() -> int {
  ; effects: throw
  %0 = call refs() : int  ; eff: throw
  echo %0
}
