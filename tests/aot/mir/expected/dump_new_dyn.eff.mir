fn Red__name(obj<Red> %this) -> string {
  ; effects: escape
  %0 = string_const "red" : string
  return %0  ; eff: escape
}

fn Blue__name(obj<Blue> %this) -> string {
  ; effects: escape
  %0 = string_const "blue" : string
  return %0  ; eff: escape
}

fn make(string %cls) -> obj<Red>|obj<Blue>|obj<stdClass> {
  ; effects: escape
  %0 = load_local cls : unknown
  %1 = new_dyn %0() : obj<Red>|obj<Blue>|obj<stdClass>
  return %1  ; eff: escape
}

fn __main() -> int {
  ; effects: throw,callUnknown
  %0 = string_const "Red" : string
  %1 = call make(%0) : obj<Red>|obj<Blue>|obj<stdClass>  ; eff: throw
  %2 = method_call %1->name() : string  ; eff: throw,callUnknown
