; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn label(int %x) -> string {
  ; effects: escape
  %0 = load_local x : int
  match %0 {
    arm {
      %1 = int_const 1 : int
      %2 = int_const 2 : int
      when %1, %2
      %3 = string_const "low" : string
      -> %3
    }
    arm {
      %4 = int_const 3 : int
      when %4
      %5 = string_const "mid" : string
      -> %5
    }
    arm default {
      %6 = string_const "high" : string
      -> %6
    }
  } => %7 : string
  return %7  ; eff: escape
}

fn __main() -> int {
  ; effects: throw
  %0 = int_const 2 : int
  %1 = call label(%0) : string  ; eff: throw
  %2 = int_const 9 : int
  %3 = call label(%2) : string  ; eff: throw
  echo %1, %3
}
