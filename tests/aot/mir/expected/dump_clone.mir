; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn Point____construct(obj<Point> %this, int %x, int %y) -> unknown {
  %0 = load_local this : obj<Point>
  %1 = load_local x : int
  %2 = store_property %0->x <- %1 : int
  %3 = load_local this : obj<Point>
  %4 = load_local y : int
  %5 = store_property %3->y <- %4 : int
}

fn dup(obj<Point> %p) -> obj<Point> {
  %0 = load_local p : obj<Point>
  %1 = clone %0 : obj<Point>
  %2 = store_local q <- %1 : obj<Point>
  %3 = load_local q : obj<Point>
  return %3
}

fn __main() -> int {
  %0 = int_const 1 : int
  %1 = int_const 2 : int
  %2 = new Point(%0, %1) : obj<Point>
  %3 = call dup(%2) : obj<Point>
  %4 = property_access %3->x : int
  echo %4
}
