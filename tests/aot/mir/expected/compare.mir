; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn cmp(int %a, int %b) -> bool {
  %0 = load_local a : int
  %1 = load_local b : int
  %2 = cmp < %0, %1 : bool
  %3 = store_local lt <- %2 : bool
  %4 = load_local lt : bool
  return %4
}

fn __main() -> int {
  %0 = int_const 1 : int
  %1 = int_const 2 : int
  %2 = call cmp(%0, %1) : bool
  echo %2
}
