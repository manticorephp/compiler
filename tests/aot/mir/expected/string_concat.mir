; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops

fn greet(string %name) -> string {
  mem_arena_enter
  %0 = string_const "hello, " : string
  %1 = load_local name : string
  %2 = concat %0, %1 : string
  %3 = store_local msg <- %2 : string
  %4 = load_local msg : string
  %5 = string_const "!" : string
  %6 = concat %4, %5 : string
  return %6
  mem_arena_leave
}

fn __main() -> int {
  %0 = string_const "world" : string
  %1 = call greet(%0) : string
  echo %1
}
