; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn bump() -> int {
  %0 = static_prop @Counter__sp_count : int
  %1 = int_const 1 : int
  %2 = add %0, %1 : int
  %3 = store_static_prop @Counter__sp_count <- %2 : int
  %4 = static_prop @Counter__sp_count : int
  return %4
}

fn __main() -> int {
  %0 = call bump() : int
  %1 = call bump() : int
  echo %0, %1
}
