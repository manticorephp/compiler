; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn sumkv(vec[int] %xs) -> int {
  %0 = int_const 0 : int
  %1 = store_local t <- %0 : int
  %2 = load_local xs : vec[int]
  foreach %2 as k => v {
    %3 = load_local t : int
    %4 = load_local k : int
    %5 = load_local v : int
    %6 = add %4, %5 : int
    %7 = add %3, %6 : int
    %8 = store_local t <- %7 : int
  }
  %9 = load_local t : int
  return %9
}

fn __main() -> int {
  %0 = int_const 10 : int
  %1 = int_const 20 : int
  %2 = int_const 30 : int
  %3 = array_lit [_ => %0, _ => %1, _ => %2] : vec[int]
  %4 = call sumkv(%3) : int
  echo %4
}
