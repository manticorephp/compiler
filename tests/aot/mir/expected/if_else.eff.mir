; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn sign(int %n) -> int {
  ; effects: escape
  %0 = load_local n : int
  %1 = int_const 0 : int
  %2 = cmp > %0, %1 : bool
  if %2 then {
    %3 = int_const 1 : int
    return %3  ; eff: escape
  } else {
    %4 = int_const -1 : int
    return %4  ; eff: escape
  }
}

fn __main() -> int {
  ; effects: throw
  %0 = int_const 5 : int
  %1 = call sign(%0) : int  ; eff: throw
  echo %1
}
