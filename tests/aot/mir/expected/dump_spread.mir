; passes: lower-from-ast, const-fold, dead-store, infer-types, narrow-returns, inline-closures, monomorphize, fuse-split-join, infer-effects, infer-alloc-kind, apply-memory-mode, insert-memory-ops, verify

fn total(vec[int] %xs) -> int {
  %0 = int_const 0 : int
  %1 = store_local t <- %0 : int
  %2 = load_local xs : vec[int]
  foreach %2 as x {
    %3 = load_local t : int
    %4 = load_local x : int
    %5 = add %3, %4 : int
    %6 = store_local t <- %5 : int
  }
  %7 = load_local t : int
  return %7
}

fn call_spread(vec[int] %args) -> int {
  %0 = load_local args : vec[int]
  %1 = spread %0 : vec[int]
  %2 = array_lit [_ => %1] : vec[int]
  %3 = call total(%2) : int
  return %3
}

fn __main() -> int {
  %0 = int_const 1 : int
  %1 = int_const 2 : int
  %2 = int_const 3 : int
  %3 = array_lit [_ => %0, _ => %1, _ => %2] : vec[int]
  %4 = call call_spread(%3) : int
  echo %4
}
